# ─── Required ─────────────────────────────────────────────────────────────────

# Telegram Bot token from @BotFather
BOT_TOKEN=1234567890:AAxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Your personal Telegram user ID — get it from @userinfobot
# Multiple admins: comma-separated  111111111,222222222
ADMIN_TELEGRAM_ID=123456789

# PostgreSQL connection string (Supabase, Neon, Railway, self-hosted, etc.)
# Supabase example (transaction pooler):
DATABASE_URL=postgresql://postgres.[ref]:[password]@aws-0-eu-central-1.pooler.supabase.com:6543/postgres

# ─── Optional ─────────────────────────────────────────────────────────────────

# Bot username without @ — used in referral deep-links
BOT_USERNAME=avito_parser_test_bot

NODE_ENV=production
LOG_LEVEL=info

# ─── Freshness filter ─────────────────────────────────────────────────────────
# Maximum age in minutes for a listing to be considered fresh and sent to user.
# Listings older than this value are saved to DB with skippedReason=TOO_OLD.
FRESH_LISTING_MAX_AGE_MINUTES=5

# Max listings to collect from Avito category page per cron check.
AVITO_MAX_LISTINGS_PER_CHECK=30

# Timezone offset (hours) of the marketplace wall-clock times. Moscow = 3 (UTC+3).
# Avito shows dates in MSK; this converts them to correct UTC instants.
LISTING_TIMEZONE_OFFSET_HOURS=3

# When true, a NEW listing whose date could not be parsed (Avito hides it on
# cards / returns 403 on detail pages) is still sent — a new externalId in a
# feed polled every 30s means it just appeared. Set false to require a parsed,
# fresh date before sending (stricter, but sends nothing when Avito hides dates).
SEND_WHEN_DATE_UNKNOWN=true

# Send strategy:
#   all    = competitor mode — send EVERY new listing in the feed (max leads).
#   strict = only send listings with a parsed date fresh within FRESH_LISTING_MAX_AGE_MINUTES.
SEND_MODE=all
